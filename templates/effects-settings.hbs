<form autocomplete="off">
    <div class="form-group">
        <label>Movement Sound</label>
        <input type="checkbox" name="enableMovementSound" {{checked enableMovementSound}}>
        <p class="notes">Play a sound when a vehicle token starts moving.</p>
    </div>

    <div class="form-group">
        <label>Ship Sound File</label>
        <div class="form-fields">
            <input type="text" name="movementSoundPath" value="{{movementSoundPath}}">
            <button type="button" data-action="browse-sound" title="Browse audio files">
                <i class="fas fa-folder-open"></i>
            </button>
        </div>
    </div>

    <div class="form-group">
        <label>Sound Volume</label>
        <div class="form-fields">
            <input type="range" name="movementSoundVolume" value="{{movementSoundVolume}}" min="0" max="1" step="0.05" data-sync-range="movementSoundVolume">
            <input type="number" value="{{movementSoundVolume}}" min="0" max="1" step="0.05" data-sync-number="movementSoundVolume">
        </div>
    </div>

    <hr>

    <div class="form-group">
        <label>Thruster Effect</label>
        <input type="checkbox" name="enableThrusterEffect" {{checked enableThrusterEffect}}>
        <p class="notes">Show a faded thrust cone underneath moving vehicle tokens.</p>
    </div>

    <div class="form-group">
        <label>Default Thruster Color</label>
        <div class="form-fields">
            <input type="color" name="thrusterColor" value="{{thrusterColor}}" data-color-picker="thrusterColor">
            <input type="text" data-color-text="thrusterColor" value="{{thrusterColor}}">
        </div>
    </div>

    {{#if hasShipProfiles}}
    <hr>

    <div class="form-group">
        <label>Ship Profile</label>
        <div class="form-fields">
            <select name="shipProfileName">
                {{#each shipOptions}}
                <option value="{{name}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                {{/each}}
            </select>
        </div>
        <p class="notes">Profiles are matched by ship name. Every vehicle with the same name uses the same profile.</p>
        <p class="notes">The sound file, sound volume, and custom exhaust color are saved to the selected profile.</p>
    </div>

    <div class="form-group">
        <label>Custom Ship Exhaust</label>
        <input type="checkbox" name="useShipThrusterColor" {{checked useShipThrusterColor}}>
        <p class="notes">Use a custom exhaust color for this ship name.</p>
    </div>

    <div class="form-group" data-ship-color-fields style="{{#unless useShipThrusterColor}}display: none;{{/unless}}">
        <label>Ship Exhaust Color</label>
        <div class="form-fields">
            <input type="color" name="shipThrusterColor" value="{{shipThrusterColor}}" data-color-picker="shipThrusterColor">
            <input type="text" data-color-text="shipThrusterColor" value="{{shipThrusterColor}}">
        </div>
    </div>
    {{/if}}

    <div class="form-group">
        <label>Thruster Length</label>
        <div class="form-fields">
            <input type="range" name="thrusterLength" value="{{thrusterLength}}" min="0.25" max="6" step="0.25" data-sync-range="thrusterLength">
            <input type="number" value="{{thrusterLength}}" min="0.25" max="6" step="0.25" data-sync-number="thrusterLength">
        </div>
    </div>

    <div class="form-group">
        <label>Thruster Width</label>
        <div class="form-fields">
            <input type="range" name="thrusterWidth" value="{{thrusterWidth}}" min="0.1" max="3" step="0.05" data-sync-range="thrusterWidth">
            <input type="number" value="{{thrusterWidth}}" min="0.1" max="3" step="0.05" data-sync-number="thrusterWidth">
        </div>
    </div>

    <footer class="sheet-footer flexrow">
        <button type="submit">
            <i class="fas fa-save"></i> Save
        </button>
    </footer>
</form>
