<form autocomplete="off">
    <div class="form-group">
        <label>Movement Sound</label>
        <input type="checkbox" name="enableMovementSound" {{checked enableMovementSound}}>
        <p class="notes">Play a sound when a vehicle token starts moving.</p>
    </div>

    <div class="form-group">
        <label>Sound File</label>
        <div class="form-fields">
            <input type="text" name="movementSoundPath" value="{{movementSoundPath}}">
            <button type="button" data-action="browse-sound" title="Browse audio files">
                <i class="fas fa-folder-open"></i>
            </button>
        </div>
    </div>

    <div class="form-group">
        <label>Sound Volume</label>
        <div class="form-fields">
            <input type="range" name="movementSoundVolume" value="{{movementSoundVolume}}" min="0" max="1" step="0.05">
            <input type="number" value="{{movementSoundVolume}}" min="0" max="1" step="0.05" onchange="this.previousElementSibling.value=this.value">
        </div>
    </div>

    <hr>

    <div class="form-group">
        <label>Thruster Effect</label>
        <input type="checkbox" name="enableThrusterEffect" {{checked enableThrusterEffect}}>
        <p class="notes">Show a faded thrust cone underneath moving vehicle tokens.</p>
    </div>

    <div class="form-group">
        <label>Thruster Color</label>
        <div class="form-fields">
            <input type="color" name="thrusterColor" value="{{thrusterColor}}">
            <input type="text" data-thruster-color-text value="{{thrusterColor}}">
        </div>
    </div>

    <div class="form-group">
        <label>Thruster Length</label>
        <div class="form-fields">
            <input type="range" name="thrusterLength" value="{{thrusterLength}}" min="0.25" max="6" step="0.25">
            <input type="number" value="{{thrusterLength}}" min="0.25" max="6" step="0.25" onchange="this.previousElementSibling.value=this.value">
        </div>
    </div>

    <div class="form-group">
        <label>Thruster Width</label>
        <div class="form-fields">
            <input type="range" name="thrusterWidth" value="{{thrusterWidth}}" min="0.1" max="3" step="0.05">
            <input type="number" value="{{thrusterWidth}}" min="0.1" max="3" step="0.05" onchange="this.previousElementSibling.value=this.value">
        </div>
    </div>

    <footer class="sheet-footer flexrow">
        <button type="submit">
            <i class="fas fa-save"></i> Save
        </button>
    </footer>
</form>
