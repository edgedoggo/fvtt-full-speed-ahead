<form autocomplete="off">
    <div class="form-group">
        <label>Movement Sound</label>
        <input type="checkbox" name="enableMovementSound" {{checked enableMovementSound}}>
        <p class="notes">Play a sound when a vehicle token starts moving.</p>
    </div>

    <div class="form-group">
        <label>Ship Sound File</label>
        <div class="form-fields">
            <input type="text" name="movementSoundPath" value="{{movementSoundPath}}">
            <button type="button" data-action="browse-sound" title="Browse audio files">
                <i class="fas fa-folder-open"></i>
            </button>
        </div>
    </div>

    <div class="form-group">
        <label>Sound Volume</label>
        <div class="form-fields">
            <input type="range" name="movementSoundVolume" value="{{movementSoundVolume}}" min="0" max="1" step="0.05" data-sync-range="movementSoundVolume">
            <input type="number" value="{{movementSoundVolume}}" min="0" max="1" step="0.05" data-sync-number="movementSoundVolume">
        </div>
    </div>

    <hr>

    <div class="form-group">
        <label>Thruster Effect</label>
        <input type="checkbox" name="enableThrusterEffect" {{checked enableThrusterEffect}}>
        <p class="notes">Show a faded thrust cone underneath moving vehicle tokens. Preview is always shown while tuning.</p>
    </div>

    {{#if hasShipProfiles}}
    <hr>

    <div class="form-group">
        <label>Ship Profile</label>
        <div class="form-fields">
            <select name="shipProfileName">
                {{#each shipOptions}}
                <option value="{{name}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                {{/each}}
            </select>
        </div>
        <p class="notes">Profiles are matched by ship name. Every vehicle with the same name uses the same profile.</p>
        {{#if isTokenConfig}}
        <p class="notes">This token is named {{tokenName}}. Saving a different profile makes this token use that profile.</p>
        {{/if}}
        <p class="notes">The sound file, sound volume, and exhaust color are saved to the selected profile.</p>
    </div>

    <div class="form-group">
        <label>Ship Exhaust Color</label>
        <div class="form-fields">
            <input type="color" name="shipThrusterColor" value="{{shipThrusterColor}}" data-color-picker="shipThrusterColor">
            <input type="text" data-color-text="shipThrusterColor" value="{{shipThrusterColor}}">
        </div>
    </div>
    {{/if}}

    <div class="form-group">
        <label>Global Scale</label>
        <div class="form-fields">
            <input type="range" name="thrusterScale" value="{{thrusterScale}}" min="-10" max="10" step="0.5" data-sync-range="thrusterScale">
            <input type="number" value="{{thrusterScale}}" min="-10" max="10" step="0.5" data-sync-number="thrusterScale">
        </div>
    </div>

    <div class="form-group">
        <label>Thruster Length</label>
        <div class="form-fields">
            <input type="range" name="thrusterLength" value="{{thrusterLength}}" min="0.25" max="12" step="0.25" data-sync-range="thrusterLength">
            <input type="number" value="{{thrusterLength}}" min="0.25" max="12" step="0.25" data-sync-number="thrusterLength">
        </div>
    </div>

    <div class="form-group">
        <label>Thruster Width</label>
        <div class="form-fields">
            <input type="range" name="thrusterWidth" value="{{thrusterWidth}}" min="0.1" max="6" step="0.05" data-sync-range="thrusterWidth">
            <input type="number" value="{{thrusterWidth}}" min="0.1" max="6" step="0.05" data-sync-number="thrusterWidth">
        </div>
    </div>

    <details>
        <summary><i class="fas fa-cog"></i> Advanced Thruster Cones</summary>

        <div class="form-group">
            <label>Cone Count</label>
            <div class="form-fields">
                <input type="range" name="coneCount" value="{{coneCount}}" min="1" max="3" step="1" data-sync-range="coneCount">
                <input type="number" value="{{coneCount}}" min="1" max="3" step="1" data-sync-number="coneCount">
            </div>
        </div>

        <div class="form-group">
            <label>Cone Spacing</label>
            <div class="form-fields">
                <input type="range" name="coneSpacing" value="{{coneSpacing}}" min="0" max="6" step="0.05" data-sync-range="coneSpacing">
                <input type="number" value="{{coneSpacing}}" min="0" max="6" step="0.05" data-sync-number="coneSpacing">
            </div>
        </div>

        {{#each cones}}
        <fieldset>
            <legend>Cone {{number}}</legend>

            {{#if @first}}
            <p class="notes">Cone 1 uses the ship exhaust color, length, and width above.</p>
            {{else}}
            <div class="form-group">
                <label>Cone {{number}} Color</label>
                <div class="form-fields">
                    <input type="color" name="cone{{number}}Color" value="{{color}}" data-color-picker="cone{{number}}Color">
                    <input type="text" data-color-text="cone{{number}}Color" value="{{color}}">
                </div>
            </div>

            <div class="form-group">
                <label>Cone {{number}} Length</label>
                <div class="form-fields">
                    <input type="range" name="cone{{number}}Length" value="{{length}}" min="0.25" max="12" step="0.25" data-sync-range="cone{{number}}Length">
                    <input type="number" value="{{length}}" min="0.25" max="12" step="0.25" data-sync-number="cone{{number}}Length">
                </div>
            </div>

            <div class="form-group">
                <label>Cone {{number}} Width</label>
                <div class="form-fields">
                    <input type="range" name="cone{{number}}Width" value="{{width}}" min="0.1" max="6" step="0.05" data-sync-range="cone{{number}}Width">
                    <input type="number" value="{{width}}" min="0.1" max="6" step="0.05" data-sync-number="cone{{number}}Width">
                </div>
            </div>
            {{/if}}
        </fieldset>
        {{/each}}
    </details>

    <footer class="sheet-footer flexrow">
        <button type="submit">
            <i class="fas fa-save"></i> Save
        </button>
    </footer>
</form>
